{
    "compilerOptions": {
        "target": "ES2022",
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": false,
        "isolatedModules": true,
        "verbatimModuleSyntax": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "types": [
            "node",
            "vitest/globals"
        ]
    },
    "include": [
        "src",
        "test",
        "vitest.config.ts",
    ],
    "exclude": [
        "src/diagram/**",
        "legacy/illustration.ts",
        "legacy/statediagram",
    ]
}