{
    "$schema": "https://typedoc.org/schema.json",
    "entryPoints": [
        "src/index.ts"
    ],
    "projectDocuments": [
        "help/use-model.md",
        "help/use-view.md",
        "help/use-editor.md",
        "help/build-your-own-editor.md",
        "help/operate-the-editor.md"
    ],
    "tsconfig": "tsconfig.json",
    "out": "docs",
    "readme": "help/index.md",
    "cleanOutputDir": true,
    "excludePrivate": true,
    "excludeInternal": true,
    "searchInDocuments": true,
    "navigation": {
        "includeCategories": true,
        "includeGroups": true,
        "includeFolders": true,
        "excludeReferences": false
    },
    "sort": [
        "documents-first",
        "source-order"
    ],
    "sortEntryPoints": false
}